{
  "name": "ts-write-tests-api",
  "version": "1.0.0",
  "description": "HFES Scenario: Write tests for a task management API",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --config jest.config.js",
    "test:visible": "jest --config jest.config.js --testPathPattern=tests/visible"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
